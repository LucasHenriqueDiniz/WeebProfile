{
  "name": "@weeb/svg-generator",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:tsc": "tsc --skipLibCheck",
    "build:check": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "echo \"Tests coming soon\"",
    "test:generator": "tsx scripts/test-svg-generator.ts",
    "audit:heights": "tsx scripts/audit-section-heights.ts",
    "audit:list-scaling": "tsx scripts/audit-list-scaling.ts",
    "generate:previews": "tsx scripts/generate-section-previews.ts",
    "generate:previews:force": "tsx scripts/generate-section-previews.ts --force",
    "generate:previews:png": "tsx scripts/generate-section-previews.ts --png",
    "watch:previews": "tsx scripts/watch-previews.ts",
    "watch:previews:all": "tsx scripts/watch-previews.ts --all"
  },
  "dependencies": {
    "@weeb/weeb-plugins": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependencies": {
    "@weeb/weeb-plugins": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.1",
    "@types/node": "^20.11.18",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright-core": "^1.40.0",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
