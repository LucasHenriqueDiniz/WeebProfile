# ============================================================
# Clerk Authentication (required)
# Create at https://dashboard.clerk.com
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ============================================================
# PostgreSQL via Drizzle (required)
# Phase 1: Supabase PostgreSQL or any Postgres instance
# Phase 2: will switch to Cloudflare D1 binding
# ============================================================
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# ============================================================
# Supabase Storage (required for SVG file serving)
# Note: auth is handled by Clerk — these are for storage only
# Phase 2/3: will migrate to Cloudflare R2
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ============================================================
# SVG Generator service
# ============================================================
SVG_GENERATOR_URL=http://localhost:3001

# ============================================================
# Cron job protection (optional)
# ============================================================
CRON_SECRET=your-random-secret-here

# ============================================================
# Site URL (optional, for canonical links)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://weebprofile.pages.dev
