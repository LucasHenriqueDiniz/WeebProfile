# ============================================================
# Clerk Authentication (required)
# Create at https://dashboard.clerk.com
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ============================================================
# Cloudflare D1 (required)
# Configured via [[d1_databases]] binding in wrangler.toml (binding = "DB")
# Local dev: wrangler d1 migrations apply weebprofile-db --local
# ============================================================

# ============================================================
# Cloudflare R2 — SVG file storage (required)
# Configured via [[r2_buckets]] binding in wrangler.toml (binding = "SVGS_BUCKET")
# R2_PUBLIC_URL is the public r2.dev (or custom domain) URL for the bucket
# ============================================================
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ============================================================
# SVG Generator service
# ============================================================
SVG_GENERATOR_URL=http://localhost:3001

# ============================================================
# Cron job protection (optional)
# ============================================================
CRON_SECRET=your-random-secret-here

# ============================================================
# Site URL (optional, for canonical links)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://weebprofile.pages.dev
