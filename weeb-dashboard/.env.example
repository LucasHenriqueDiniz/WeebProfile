# ============================================================
# Clerk Authentication (required)
# Create at https://dashboard.clerk.com
# VITE_CLERK_PUBLISHABLE_KEY is inlined into the client bundle at build
# time by Vite. CLERK_PUBLISHABLE_KEY / CLERK_SECRET_KEY are read by the
# Cloudflare Pages Functions at runtime (set via wrangler.toml [vars] /
# `wrangler pages secret put`).
# ============================================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ============================================================
# Cloudflare D1 (required)
# Configured via the [[d1_databases]] binding in wrangler.toml,
# not via an env var. Run `wrangler d1 create weebprofile-db` and
# fill in the database_id, then `wrangler d1 migrations apply`.
# ============================================================

# ============================================================
# Supabase Storage (required for SVG file serving)
# Note: auth is handled by Clerk — these are for storage only
# Phase 3: will migrate to Cloudflare R2
# ============================================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ============================================================
# SVG Generator service (read by Cloudflare Pages Functions)
# ============================================================
SVG_GENERATOR_URL=http://localhost:3001

# ============================================================
# Cron job protection (optional)
# ============================================================
CRON_SECRET=your-random-secret-here

# ============================================================
# Site URL (optional, for canonical links)
# ============================================================
VITE_SITE_URL=https://weebprofile.pages.dev
