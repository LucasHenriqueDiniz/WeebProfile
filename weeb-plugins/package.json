{
  "name": "@weeb/weeb-plugins",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "default": "./dist/plugins/index.js"
    },
    "./plugins/metadata": {
      "types": "./dist/plugins/metadata.d.ts",
      "default": "./dist/plugins/metadata.js"
    },
    "./plugins/manager": {
      "types": "./dist/plugins/manager.d.ts",
      "default": "./dist/plugins/manager.js"
    },
    "./plugins/tags": {
      "types": "./dist/plugins/tags.d.ts",
      "default": "./dist/plugins/tags.js"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "default": "./dist/styles/index.js"
    },
    "./styles/server": {
      "types": "./dist/styles/server.d.ts",
      "default": "./dist/styles/server.js"
    },
    "./fonts/server": {
      "types": "./dist/fonts/server.d.ts",
      "default": "./dist/fonts/server.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "default": "./dist/themes/index.js"
    },
    "./themes/theme-utils": {
      "types": "./dist/themes/theme-utils.d.ts",
      "default": "./dist/themes/theme-utils.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "default": "./dist/templates/index.js"
    }
  },
  "dependencies": {
    "@octokit/graphql": "^8.1.1",
    "@octokit/rest": "^21.0.2",
    "@types/glob": "^9.0.0",
    "bottleneck": "^2.19.5",
    "country-flag-icons": "^1.6.4",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.22",
    "glob": "^13.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsup": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "test": "vitest run",
    "build": "pnpm validate && pnpm generate-metadata && pnpm generate-types && pnpm generate-section-previews && pnpm generate-tailwind-css && pnpm generate-style-index && pnpm generate-embedded-assets && tsup && pnpm verify-no-relative-imports",
    "clean": "tsx scripts/clean-compiled-files.ts",
    "validate": "tsx scripts/validate-plugins.ts",
    "validate-previews": "tsx scripts/validate-previews.ts --warn-only",
    "check-translations": "tsx scripts/check-translations.ts",
    "generate-metadata": "tsx scripts/generate-metadata.ts",
    "generate-types": "tsx scripts/generate-types.ts",
    "generate-preview-images": "tsx scripts/generate-preview-images.ts",
    "generate-section-previews": "tsx scripts/generate-section-previews.ts",
    "generate-tailwind-css": "tsx scripts/generate-tailwind-css.ts",
    "generate-style-index": "tsx scripts/generate-style-index.ts",
    "generate-duolingo-assets": "tsx scripts/generate-duolingo-assets.ts",
    "generate-embedded-assets": "tsx scripts/generate-embedded-assets.ts",
    "verify-no-relative-imports": "node scripts/verify-no-relative-imports.js",
    "dev": "tsc --watch --project tsconfig.dev.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "create-plugin": "tsx scripts/create-plugin.ts",
    "update-lastfm-mock": "tsx scripts/update-lastfm-mock-data.ts",
    "prepublishOnly": "pnpm validate && pnpm generate-metadata && pnpm generate-types && pnpm generate-section-previews && pnpm generate-tailwind-css && pnpm generate-style-index && pnpm generate-embedded-assets"
  }
}
